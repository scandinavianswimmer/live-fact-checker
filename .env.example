# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Deepgram (master key — used server-side to mint short-lived tokens for the browser)
# IMPORTANT: this key needs the "Member" role or higher to mint browser tokens
# via /v1/auth/grant. The default "USAGE" key cannot grant tokens. Create a new
# key in the Deepgram dashboard → API Keys → New Key → Project Role: Member.
DEEPGRAM_API_KEY=

# Anthropic — Claim Detector + Verdict Scoring (Haiku for speed)
ANTHROPIC_API_KEY=
ANTHROPIC_HAIKU_MODEL=claude-haiku-4-5-20251001

# Perplexity Sonar — verification engine
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar

# Stripe (Week 2)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Sentry (optional)
SENTRY_DSN=

# Cost / safety guardrails
LFC_CLAIM_MIN_CONFIDENCE=70
LFC_CLAIM_WINDOW_SECONDS=30
LFC_CLAIM_TICK_SECONDS=5
LFC_MAX_SESSION_MINUTES=180
